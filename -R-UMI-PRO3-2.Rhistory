exact_mass = internal.standard$Exact_mass[i],
retention_time = internal.standard$Retention_time[i]*60,
ppm = 10,rt.err = 10,ion_mode = 1)$feature_id
ft.neg <- findFeature(object ,
exact_mass = internal.standard$Exact_mass[i],
